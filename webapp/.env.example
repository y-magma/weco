# Live WID.world API (optional — takes priority over the local CSV dump).
# Hex string from the official R package: load("R/sysdata.rda"); paste(sprintf("%02x", api_key), collapse="")
NUXT_PUBLIC_WID_API_KEY=
NUXT_PUBLIC_WID_API_BASE_URL=https://rfap9nitz6.execute-api.eu-west-1.amazonaws.com/prod

# Local WID dump (used when NUXT_PUBLIC_WID_API_KEY is unset).
# Leave empty to use the default: webapp/data/WID_DATA (a symlink to the dump).
WID_DATA_DIR=
